# ============================================================================
# Lex Study Foundation — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# --- Gemini API Keys (comma-separated for key rotation) ---
# Get keys at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-1,your-gemini-key-2

# --- Base model (HuggingFace ID) ---
BASE_MODEL=google/gemma-4-E4B-it

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
